  <!-- Motion accents -->
  <circle cx="456" cy="80" r="4" fill="#2563EB" opacity="0.8"><animate attributeName="opacity" values="0.2;1;0.2" dur="3s" repeatCount="indefinite"/></circle>
  <circle cx="910" cy="560" r="4" fill="#06B6D4" opacity="0.8"><animate attributeName="opacity" values="0.3;1;0.3" dur="2.4s" repeatCount="indefinite"/></circle>
  <circle cx="1032" cy="544" r="4" fill="#10B981" opacity="0.8"><animate attributeName="opacity" values="0.3;1;0.3" dur="2.7s" repeatCount="indefinite"/></circle>
