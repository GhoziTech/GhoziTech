            <animate attributeName="stroke-opacity" values="0.28;0.72;0.28" dur="4.2s" repeatCount="indefinite"/>
          </rect>
          <text x="40.0" y="18" text-anchor="middle" font-size="12" font-family="Arial, Helvetica, sans-serif" font-weight="700" fill="#0F172A">GSAP</text>
        </g>

    <!-- social icons -->
