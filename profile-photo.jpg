    <text x="510" y="154" font-size="12" font-family="monospace" fill="#10B981" letter-spacing="2.1">GREETING / USER SIGNAL</text>
    <text x="510" y="212" font-size="42" font-family="Arial, Helvetica, sans-serif" font-weight="800" fill="#0F172A">Hi, I&apos;m Hafid Ghozi</text>

    <!-- animated typing roles -->
    <g>
      <text x="510" y="246" font-size="22" font-family="monospace" fill="url(#accentGrad)" opacity="1">Frontend Engineer<animate attributeName="opacity" values="1;1;0;0;0;1" dur="15s" repeatCount="indefinite"/></text>
      <text x="510" y="246" font-size="22" font-family="monospace" fill="url(#accentGrad)" opacity="0">Full Stack Developer<animate attributeName="opacity" values="0;0;1;1;0;0" dur="15s" repeatCount="indefinite"/></text>
      <text x="510" y="246" font-size="22" font-family="monospace" fill="url(#accentGrad)" opacity="0">AI Enthusiast<animate attributeName="opacity" values="0;0;0;0;1;1" dur="15s" repeatCount="indefinite"/></text>
      <text x="744" y="246" font-size="22" font-family="monospace" fill="#0F172A">|<animate attributeName="opacity" values="1;0;1" dur="1s" repeatCount="indefinite"/></text>
    </g>

    <!-- sequential detailed specs -->
    <g>
      <text x="510" y="290" font-size="11" font-family="monospace" fill="#64748B" letter-spacing="1.7" opacity="0">[01] LOCATION<animate attributeName="opacity" values="0;1;1" dur="0.6s" begin="0.2s" fill="freeze"/></text>
      <text x="610" y="290" font-size="15" font-family="Arial, Helvetica, sans-serif" fill="#0F172A" opacity="0">Surakarta, Central Java, Indonesia<animate attributeName="opacity" values="0;1;1" dur="0.7s" begin="0.5s" fill="freeze"/></text>
      <text x="510" y="318" font-size="11" font-family="monospace" fill="#64748B" letter-spacing="1.7" opacity="0">[02] EDUCATION<animate attributeName="opacity" values="0;1;1" dur="0.6s" begin="0.8s" fill="freeze"/></text>
      <text x="610" y="318" font-size="15" font-family="Arial, Helvetica, sans-serif" fill="#0F172A" opacity="0">PKBM Kenangan • Ngudi Ilmu • SD Muhammadiyah 7<animate attributeName="opacity" values="0;1;1" dur="0.7s" begin="1.1s" fill="freeze"/></text>
      <text x="510" y="346" font-size="11" font-family="monospace" fill="#64748B" letter-spacing="1.7" opacity="0">[03] CURRENT FOCUS<animate attributeName="opacity" values="0;1;1" dur="0.6s" begin="1.4s" fill="freeze"/></text>
      <text x="610" y="346" font-size="15" font-family="Arial, Helvetica, sans-serif" fill="#0F172A" opacity="0">Web systems, motion UI, AI automation, Germany prep<animate attributeName="opacity" values="0;1;1" dur="0.7s" begin="1.7s" fill="freeze"/></text>
      <text x="510" y="374" font-size="11" font-family="monospace" fill="#64748B" letter-spacing="1.7" opacity="0">[04] PORTFOLIO<animate attributeName="opacity" values="0;1;1" dur="0.6s" begin="2.0s" fill="freeze"/></text>
      <text x="610" y="374" font-size="15" font-family="Arial, Helvetica, sans-serif" fill="#2563EB" opacity="0">ghozitech.github.io<animate attributeName="opacity" values="0;1;1" dur="0.7s" begin="2.3s" fill="freeze"/></text>
      <text x="510" y="402" font-size="11" font-family="monospace" fill="#64748B" letter-spacing="1.7" opacity="0">[05] EMAIL<animate attributeName="opacity" values="0;1;1" dur="0.6s" begin="2.6s" fill="freeze"/></text>
      <text x="610" y="402" font-size="15" font-family="Arial, Helvetica, sans-serif" fill="#0F172A" opacity="0">hafidghozii01@gmail.com<animate attributeName="opacity" values="0;1;1" dur="0.7s" begin="2.9s" fill="freeze"/></text>
    </g>

    <text x="510" y="442" font-size="12" font-family="monospace" fill="#475569" letter-spacing="2">CORE TECHNOLOGIES</text>

    <g transform="translate(510 454)">
          <rect x="0" y="0" width="88" height="28" rx="14" fill="#FFFFFF" fill-opacity="0.02" stroke="url(#accentGrad)" stroke-opacity="0.50">
            <animate attributeName="stroke-opacity" values="0.28;0.72;0.28" dur="4.2s" repeatCount="indefinite"/>
          </rect>
          <text x="44.0" y="18" text-anchor="middle" font-size="12" font-family="Arial, Helvetica, sans-serif" font-weight="700" fill="#0F172A">React</text>
        </g><g transform="translate(606 454)">
          <rect x="0" y="0" width="128" height="28" rx="14" fill="#FFFFFF" fill-opacity="0.02" stroke="url(#accentGrad)" stroke-opacity="0.50">
            <animate attributeName="stroke-opacity" values="0.28;0.72;0.28" dur="4.2s" repeatCount="indefinite"/>
          </rect>
          <text x="64.0" y="18" text-anchor="middle" font-size="12" font-family="Arial, Helvetica, sans-serif" font-weight="700" fill="#0F172A">TypeScript</text>
        </g><g transform="translate(742 454)">
          <rect x="0" y="0" width="96" height="28" rx="14" fill="#FFFFFF" fill-opacity="0.02" stroke="url(#accentGrad)" stroke-opacity="0.50">
            <animate attributeName="stroke-opacity" values="0.28;0.72;0.28" dur="4.2s" repeatCount="indefinite"/>
          </rect>
          <text x="48.0" y="18" text-anchor="middle" font-size="12" font-family="Arial, Helvetica, sans-serif" font-weight="700" fill="#0F172A">Python</text>
        </g><g transform="translate(846 454)">
          <rect x="0" y="0" width="72" height="28" rx="14" fill="#FFFFFF" fill-opacity="0.02" stroke="url(#accentGrad)" stroke-opacity="0.50">
            <animate attributeName="stroke-opacity" values="0.28;0.72;0.28" dur="4.2s" repeatCount="indefinite"/>
          </rect>
